
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Despesa {
  id          String   @id @default(uuid())
  descricao   String
  data        DateTime @default(now())
  valor       Float
  pago       Boolean  @default(false)

  @@map ("despesas")
}